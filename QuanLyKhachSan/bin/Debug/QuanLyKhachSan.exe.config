<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <startup>
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
    </startup>
    <connectionStrings>
        <!--
            SỬA LẠI: Data Source = tên máy chủ SQL của bạn
            Ví dụ:
              - Máy local:        Data Source=localhost
              - Tên máy cụ thể:   Data Source=DESKTOP-ABC\SQLEXPRESS
              - Dùng .\SQLEXPRESS: Data Source=.\SQLEXPRESS
        -->
        <add name="QuanLyKhachSan"
             connectionString="Data Source=THAON5\THAO;Initial Catalog=QuanLyKhachSan2;Integrated Security=True;TrustServerCertificate=True"
             providerName="System.Data.SqlClient" />
    </connectionStrings>
    <appSettings>
        <add key="AppName" value="Quản Lý Khách Sạn" />
        <add key="Version" value="1.0.0" />
    </appSettings>
</configuration>
